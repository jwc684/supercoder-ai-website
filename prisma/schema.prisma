// Prisma schema for 슈퍼코더 AI Interviewer website
// Based on 기획문서 7.2
// AdminUser는 Supabase Auth 의 auth.users.id 와 1:1 매핑 (id == auth user id).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── 관리자 ───
// Supabase Auth 에서 사용자를 생성하면 auth.users 에 레코드가 생긴다.
// 본 테이블의 id 는 해당 auth.users.id (UUID) 와 동일하게 사용한다.
model AdminUser {
  id        String     @id // == Supabase auth.users.id
  email     String     @unique
  name      String
  role      AdminRole  @default(EDITOR)
  blogPosts BlogPost[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@map("admin_users")
}

enum AdminRole {
  SUPER_ADMIN
  EDITOR
}

// ─── 블로그 ───
model BlogPost {
  id          String       @id @default(cuid())
  title       String
  slug        String       @unique
  content     Json         // Tiptap JSON
  excerpt     String?
  thumbnail   String?      // 이미지 URL (Supabase Storage)
  category    BlogCategory @default(INSIGHT)
  tags        String[]
  status      PostStatus   @default(DRAFT)
  publishedAt DateTime?
  seoTitle    String?
  seoDesc     String?
  author      AdminUser    @relation(fields: [authorId], references: [id])
  authorId    String
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([slug])
  @@index([status, publishedAt])
  @@index([category])
  @@map("blog_posts")
}

enum BlogCategory {
  AI_HIRING // AI 채용
  INSIGHT // HR 인사이트
  CASE_STUDY // 고객 사례
  PRODUCT_UPDATE // 제품 업데이트
}

enum PostStatus {
  DRAFT
  PUBLISHED
}

// ─── 약관 ───
model Terms {
  id            String    @id @default(cuid())
  title         String
  type          TermsType
  content       Json // Tiptap JSON
  version       String    @default("1.0")
  effectiveDate DateTime
  isActive      Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([type, isActive])
  @@map("terms")
}

enum TermsType {
  PRIVACY // 개인정보처리방침
  ENTERPRISE // 기업용 이용약관
  CANDIDATE // 지원자용 이용약관
  MARKETING // 마케팅 동의
}

// ─── FAQ ───
// Maki .c_faq 섹션에 사용하는 질문/답변 카드.
// 랜딩 페이지(공개) 에는 isPublished=true 만 order asc 로 노출.
model Faq {
  id          String   @id @default(cuid())
  question    String
  answer      Json // Tiptap JSON
  order       Int      @default(0)
  isPublished Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([isPublished, order])
  @@map("faqs")
}

// ─── 도입 문의 ───
model Inquiry {
  id            String        @id @default(cuid())
  company       String
  name          String
  email         String
  phone         String
  jobTitle      String?
  hireSize      String?
  interests     String[]
  message       String?
  privacyAgreed Boolean       @default(true)
  status        InquiryStatus @default(NEW)
  adminNote     String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([status])
  @@index([createdAt])
  @@map("inquiries")
}

enum InquiryStatus {
  NEW
  REVIEWED
  CONTACTED
  COMPLETED
}

// ─── 소개서 다운로드 ───
model Download {
  id        String   @id @default(cuid())
  company   String
  name      String
  email     String
  jobTitle  String?
  phone     String?
  interests String[]
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@map("downloads")
}
