// Prisma schema for 슈퍼코더 AI Interviewer website
// Based on 기획문서 7.2
// AdminUser는 Supabase Auth 의 auth.users.id 와 1:1 매핑 (id == auth user id).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── 관리자 ───
// Supabase Auth 에서 사용자를 생성하면 auth.users 에 레코드가 생긴다.
// 본 테이블의 id 는 해당 auth.users.id (UUID) 와 동일하게 사용한다.
model AdminUser {
  id        String     @id // == Supabase auth.users.id
  email     String     @unique
  name      String
  role      AdminRole  @default(EDITOR)
  blogPosts BlogPost[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@map("admin_users")
}

enum AdminRole {
  SUPER_ADMIN
  EDITOR
}

// ─── 블로그 ───
model BlogPost {
  id          String       @id @default(cuid())
  title       String
  slug        String       @unique
  content     Json         // Tiptap JSON
  excerpt     String?
  thumbnail   String?      // 이미지 URL (Supabase Storage)
  category    BlogCategory @default(INSIGHT)
  tags        String[]
  status      PostStatus   @default(DRAFT)
  publishedAt DateTime?
  seoTitle    String?
  seoDesc     String?
  // 카운터 캐시 — /blog/[slug] 방문 시 POST /api/page-views 에서 increment.
  // 대시보드의 "블로그 조회수" 위젯이 pageView.groupBy 대신 이 컬럼으로 orderBy.
  viewCount   Int          @default(0)
  author      AdminUser    @relation(fields: [authorId], references: [id])
  authorId    String
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([slug])
  @@index([status, publishedAt])
  @@index([category])
  @@index([viewCount(sort: Desc)])
  @@map("blog_posts")
}

enum BlogCategory {
  AI_HIRING // AI 채용
  INSIGHT // HR 인사이트
  CASE_STUDY // 고객 사례
  PRODUCT_UPDATE // 제품 업데이트
}

enum PostStatus {
  DRAFT
  PUBLISHED
}

// ─── 약관 ───
model Terms {
  id            String    @id @default(cuid())
  title         String
  type          TermsType
  content       Json // Tiptap JSON
  version       String    @default("1.0")
  effectiveDate DateTime
  isActive      Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([type, isActive])
  @@map("terms")
}

enum TermsType {
  PRIVACY // 개인정보처리방침
  ENTERPRISE // 기업용 이용약관
  CANDIDATE // 지원자용 이용약관
  MARKETING // 마케팅 동의
}

// ─── 페이지 SEO 메타 ───
// 정적 페이지(/, /blog, /contact, /download, /trial, /privacy, /terms-*, /404)
// 의 관리자 편집 가능한 SEO 메타데이터. 블로그 글은 BlogPost.seoTitle/seoDesc/thumbnail
// 을 직접 사용 (이 테이블에 포함 안 됨).
// path 가 PK. 관리자 /admin/seo 에서 편집 가능.
model PageMeta {
  id              String   @id @default(cuid())
  path            String   @unique // "/", "/blog", "/contact", ...
  title           String
  description     String
  socialImage     String? // Supabase Storage public URL (1200x630)
  socialImagePath String? // Storage 내부 경로 (삭제용)
  indexable       Boolean  @default(true) // false 면 robots: noindex
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([path])
  @@map("page_meta")
}

// ─── 행동 분석 카운터 (docs/analytics-spec.md 참고) ───
// Raw event 저장 안 함. 카운터 only (upsert + increment).
// DB 행 수 O(섹션×페이지) = 상수.

// 섹션 도달률 — IntersectionObserver 50% 가시 시 세션당 1회 카운트
model SectionView {
  id        String   @id @default(cuid())
  path      String // 이벤트 발생 페이지 (보통 "/")
  section   String // "hero", "pain_points", ...
  viewCount Int      @default(0)
  updatedAt DateTime @updatedAt

  @@unique([path, section])
  @@index([path, viewCount(sort: Desc)])
  @@map("section_views")
}

// CTA 클릭 — data-track 속성이 있는 요소 클릭 시 매번 카운트
model CtaClick {
  id         String   @id @default(cuid())
  path       String
  label      String // "cta_hero_contact", "cta_floating_inquiry", ...
  clickCount Int      @default(0)
  updatedAt  DateTime @updatedAt

  @@unique([path, label])
  @@index([path, clickCount(sort: Desc)])
  @@map("cta_clicks")
}

// 페이지 체류 시간 — pagehide/visibilitychange 시 ms 전송, 누적+샘플수
model PageDwell {
  id          String   @id @default(cuid())
  path        String   @unique
  totalMs     BigInt   @default(0) // 누적 ms (평균 = totalMs / sampleCount)
  sampleCount Int      @default(0)
  updatedAt   DateTime @updatedAt

  @@map("page_dwell")
}

// 시간대별 방문 — 0~23시 카운터 (서버 시각 기준, 누적 all-time)
// "오후 2~4시에 방문 집중" 같은 패턴 파악용. 24 rows only.
model HourlyView {
  hour      Int      @unique // 0~23
  viewCount Int      @default(0)
  updatedAt DateTime @updatedAt

  @@map("hourly_views")
}

// 디바이스별 방문 — UA 파싱 결과 카운터
model DeviceView {
  id        String   @id @default(cuid())
  path      String
  device    String // "desktop" | "mobile" | "tablet"
  viewCount Int      @default(0)
  updatedAt DateTime @updatedAt

  @@unique([path, device])
  @@index([device, viewCount(sort: Desc)])
  @@map("device_views")
}

// ─── 통계 싱글톤 (카운터 캐시) ───
// 대시보드의 COUNT 쿼리 9개를 단일 row 조회로 대체.
// Mutation API 가 $transaction 으로 원자적 increment 수행.
// id 는 항상 "singleton" — 1 행만 존재.
// 드리프트 발생 시 scripts/seed-stats.mjs 로 실제값 재계산.
model Stats {
  id                 String   @id @default("singleton")
  inquiriesTotal     Int      @default(0)
  inquiriesNew       Int      @default(0) // status=NEW 개수만 별도 추적
  downloadsTotal     Int      @default(0)
  blogPostsTotal     Int      @default(0)
  blogPostsPublished Int      @default(0)
  pageViewsTotal     Int      @default(0)
  updatedAt          DateTime @updatedAt

  @@map("stats")
}

// ─── 페이지 방문 통계 ───
// 공개 페이지 방문 기록. 클라이언트 마운트 시 POST /api/page-views 로 단순 append.
// path 단위 집계로 관리자 대시보드에 상위 페이지 + 블로그 조회수 표시.
model PageView {
  id        String   @id @default(cuid())
  path      String // 정규화된 경로 (예: "/", "/blog", "/blog/ai-science-...")
  referer   String? // HTTP referer (선택)
  userAgent String? // 간단 UA (선택, 봇 필터링용)
  createdAt DateTime @default(now())

  @@index([path, createdAt])
  @@index([createdAt])
  @@map("page_views")
}

// ─── 서비스 소개서 (PDF) ───
// 관리자가 업로드한 브로셔 파일 기록. 가장 최근(createdAt desc)이 "현재 활성" 브로셔.
// 공개 /download 페이지는 이 테이블의 최신 레코드 URL 을 사용.
model Brochure {
  id        String   @id @default(cuid())
  filename  String // 원본 파일명
  url       String // Supabase Storage public URL
  path      String // Storage 내부 경로 (삭제 시 사용)
  size      Int // bytes
  mime      String // 주로 application/pdf
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@map("brochures")
}

// ─── FAQ ───
// Maki .c_faq 섹션에 사용하는 질문/답변 카드.
// 랜딩 페이지(공개) 에는 isPublished=true 만 order asc 로 노출.
model Faq {
  id          String   @id @default(cuid())
  question    String
  answer      Json // Tiptap JSON
  order       Int      @default(0)
  isPublished Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([isPublished, order])
  @@map("faqs")
}

// ─── 레퍼런스 고객 로고 ───
// 랜딩 페이지 LogoMarquee 에 노출. admin 에서 업로드·이름·순서·공개 여부 관리.
model Logo {
  id          String   @id @default(cuid())
  name        String   // 업체명 (관리자가 편집)
  url         String   // Supabase public URL
  storagePath String   // Supabase storage path (delete 시 사용)
  sortOrder   Int      @default(0)
  isVisible   Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([isVisible, sortOrder])
  @@map("logos")
}

// ─── 도입 문의 ───
model Inquiry {
  id            String        @id @default(cuid())
  company       String
  name          String
  email         String
  phone         String
  jobTitle      String?
  hireSize      String?
  interests     String[]
  message       String?
  // ─ 법적 동의 3종 ─
  ageOver14       Boolean @default(false)
  privacyAgreed   Boolean @default(true) // 과거 row 호환 — 기존엔 제출 = true 간주
  marketingAgreed Boolean @default(false)
  status        InquiryStatus @default(NEW)
  adminNote     String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([status])
  @@index([createdAt])
  @@map("inquiries")
}

enum InquiryStatus {
  NEW
  REVIEWED
  CONTACTED
  COMPLETED
}

// ─── 소개서 다운로드 ───
model Download {
  id        String   @id @default(cuid())
  company   String
  name      String
  email     String
  jobTitle  String?
  phone     String?
  interests String[]
  // ─ 법적 동의 (2026-04+ 추가) ─
  ageOver14       Boolean  @default(false)
  privacyAgreed   Boolean  @default(false)
  marketingAgreed Boolean  @default(false)
  // ─ 이메일 트래킹 (2026-04+ 추가) ─
  emailSentAt         DateTime?
  emailSendError      String?   // 발송 실패 시 에러 메시지 (최대 500 char trim)
  emailOpenCount      Int       @default(0)
  emailFirstOpenedAt  DateTime?
  emailClickCount     Int       @default(0)
  emailFirstClickedAt DateTime?
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@map("downloads")
}
