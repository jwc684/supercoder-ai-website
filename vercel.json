{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "regions": ["icn1"],
  "buildCommand": "prisma generate && prisma migrate deploy && next build",
  "functions": {
    "app/api/**/*.ts": {
      "maxDuration": 30
    },
    "app/api/upload/route.ts": {
      "maxDuration": 60
    },
    "app/api/brochure/route.ts": {
      "maxDuration": 60
    }
  }
}
