# Supabase (Project Settings → API Keys)
# 2025 이후 신규 API Key 체계 사용:
#   Publishable Key: sb_publishable_xxxxx (브라우저 노출 가능)
#   Secret Key:      sb_secret_xxxxx      (서버 전용, 절대 노출 금지)
# 레거시 anon / service_role JWT 키도 여전히 동작하나 신규 체계가 권장됩니다.
# 참고: https://supabase.com/docs/guides/api/api-keys

NEXT_PUBLIC_SUPABASE_URL="https://YOUR-PROJECT.supabase.co"
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY="sb_publishable_xxxxx"
SUPABASE_SECRET_KEY="sb_secret_xxxxx"

# Supabase Postgres (Project Settings → Database → Connection string)
# DATABASE_URL: Transaction pooler (port 6543) — 런타임에서 앱이 사용
# DIRECT_URL:   Session/Direct (port 5432)     — Prisma 마이그레이션이 사용
DATABASE_URL="postgresql://postgres.YOUR-PROJECT:YOUR-PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
DIRECT_URL="postgresql://postgres.YOUR-PROJECT:YOUR-PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres"

# Site URL — sitemap/robots/OpenGraph 의 baseURL 로 사용.
# 로컬 개발에선 생략 가능 (기본 https://supercoder.ai).
# Vercel 배포 시 실제 도메인으로 설정 (예: https://www.supercoder.ai).
NEXT_PUBLIC_SITE_URL="https://supercoder.ai"
